# Copy this file to ".env" for local development, or set these as
# Environment Variables in Render for production.
#
# Leave BOTH blank/unset to use a local file database (./data/wave3.db).
# Set BOTH to run against Turso (production).

# From your Turso database (starts with libsql://)
DATABASE_URL=

# The Turso auth token you generated for that database (SECRET — never commit)
DATABASE_AUTH_TOKEN=
